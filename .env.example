# Supabase — Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your_key
DEFAULT_MODEL=deepseek/deepseek-v4-flash

# Публичный URL приложения (обязательно для OAuth и ЮKassa return URL)
NEXT_PUBLIC_APP_URL=https://grill.maxima-consulting.ru

# ЮKassa — https://yookassa.ru
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key

# Должен совпадать с app_config.webhook_secret в Supabase
WEBHOOK_SECRET=generate_a_long_random_string

# VIP: полный доступ без оплаты (через запятую)
VIP_EMAILS=

# Dev-only: пропуск оплаты локально (на prod — false)
DEV_SKIP_PAYMENT=false
NEXT_PUBLIC_DEV_SKIP_PAYMENT=false

# В Docker-образе уже задан; для локального PDF без Docker — опционально
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
